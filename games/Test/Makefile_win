.PHONY: all run clean

CC = gcc

CFLAGS = -Wall -Wextra -g -I. -I../../engine -DPLATFORM_WIN
LDFLAGS = -lmingw32 -lSDL2main -lSDL2

TARGET = build_win/game.exe
SRC = \
	src_win/main_win.c \
	../../engine/fox_draw.c \
	../../engine/fox_scene.c

all:
	mkdir -p build_win
	$(CC) $(SRC) -o $(TARGET) $(CFLAGS) $(LDFLAGS)

run: all
	./$(TARGET)

clean:
	rm -rf build_win